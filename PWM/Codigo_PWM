#include <MKL25Z4.h>

#define RS 0x04
#define EN 0x20
#define BTN_MENU (1 << 12)
#define BTN_STOP (1 << 13)


volatile int in_manual_mode = 0;
volatile int in_auto_mode = 0;
volatile int emergency_stop = 0;
volatile int refresh_lcd = 0;
int last_level = -1; // Para evitar que el modo auto parpadee


void delayMs(int n);
void delayUs(int n);
void LCD_init(void);
void LCD_command(unsigned char cmd);
void LCD_data(unsigned char data);
void LCD_print(char *str);
void LCD_nibble(unsigned char data);
void keypad_init(void);
char keypad_getkey(void);
void show_menu(void);
void PWM_init(void);
void update_speed(uint16_t duty_val);
void ADC0_init(void);
uint16_t ADC0_read(void);
void buttons_init(void);

//INTERRUPCIONES PORTA y para los Push buttons
void PORTA_IRQHandler(void) {
    if (PORTA->ISFR & BTN_STOP) {//Boton de detener de emergencia
        update_speed(0);
        emergency_stop = 1;
        in_manual_mode = 0;
        in_auto_mode = 0;
        refresh_lcd = 1;
        PORTA->ISFR = BTN_STOP;
    }
    else if (PORTA->ISFR & BTN_MENU) {//Boton para regresar al menu
        update_speed(0);
        in_manual_mode = 0;
        in_auto_mode = 0;
        emergency_stop = 0;
        refresh_lcd = 2;
        PORTA->ISFR = BTN_MENU;
    }
}

int main(void) {
    keypad_init();
    LCD_init();
    PWM_init();
    ADC0_init();
    buttons_init();

    show_menu();

    char key;
    uint16_t adc_val;
    int current_level;

    while(1) {
    	if (refresh_lcd == 1) {
    	        LCD_command(0x01);
    	        LCD_print("!!! STOP !!!");
    	        refresh_lcd = 0;
    	    }
    	    else if (refresh_lcd == 2) {
    	        show_menu();
    	        refresh_lcd = 0;
    	    }

    	    if (emergency_stop) continue;

    	    key = keypad_getkey();

        if (emergency_stop) continue;

        key = keypad_getkey();

        // Seleccion de Modo manual o automatico
        if (in_manual_mode == 0 && in_auto_mode == 0) {
            if (key == '1') {
                in_manual_mode = 1;
                LCD_command(0x01);
                LCD_print("SELECT SPEED:");
                LCD_command(0xC0);
                LCD_print("1:L 2:M 3:MH 4:H"); //Las 4 opciones del duty cycle
                delayMs(200);
            }
            else if (key == '2') {
                in_auto_mode = 1;
                LCD_command(0x01);
                LCD_print("AUTO MODE ON");
                delayMs(500);
            }
        }
        // 2. Ejecucion Modo Manual
        else if (in_manual_mode == 1) {
            if (key != 0) {
                LCD_command(0x01);
                if (key == '1') { update_speed(10925); LCD_print("SPEED: 25%"); }
                else if (key == '2') { update_speed(21851); LCD_print("SPEED: 50%"); }
                else if (key == '3') { update_speed(32776); LCD_print("SPEED: 75%"); }
                else if (key == '4') { update_speed(43702); LCD_print("SPEED: 100%"); }

                delayMs(800);
                LCD_command(0x01);
                LCD_print("SELECT SPEED:");
                LCD_command(0xC0);
                LCD_print("1:L 2:M 3:MH 4:H");
            }
        }
        // 3. Ejecucion Modo Automatico
        else if (in_auto_mode == 1) {
            adc_val = ADC0_read();

            // Determinar nivel
            if (adc_val < 16384)      current_level = 1;
            else if (adc_val < 32768) current_level = 2;
            else if (adc_val < 49152) current_level = 3;
            else                      current_level = 4;

            // SOLO actualizar LCD y PWM si el nivel cambio
            if (current_level != last_level) {
                LCD_command(0x01);
                LCD_print("AUTO SPEED:");
                LCD_command(0xC0);
                if (current_level == 1) { update_speed(10925); LCD_print("NIVEL 1 - 25%"); }
                else if (current_level == 2) { update_speed(21851); LCD_print("NIVEL 2 - 50%"); }
                else if (current_level == 3) { update_speed(32776); LCD_print("NIVEL 3 - 75%"); }
                else if (current_level == 4) { update_speed(43702); LCD_print("NIVEL 4 - 100%"); }
                last_level = current_level;
            }
        }

        delayMs(200); // Estabilizacion general y anti-rebote
    }
}

//Actualizar la velocidad
void update_speed(uint16_t duty_val) {
    TPM0->CONTROLS[1].CnV = duty_val; //
}


//PWM
void PWM_init(void) {
    SIM->SCGC6 |= SIM_SCGC6_TPM0_MASK;
    SIM->SOPT2 |= SIM_SOPT2_TPMSRC(1);
    SIM->SCGC5 |= SIM_SCGC5_PORTD_MASK;
    PORTD->PCR[1] = PORT_PCR_MUX(4); // PTD1
    TPM0->MOD = 43702; // 60Hz
    TPM0->CONTROLS[1].CnSC = TPM_CnSC_MSB_MASK | TPM_CnSC_ELSB_MASK;
    TPM0->SC = TPM_SC_CMOD(1) | TPM_SC_PS(7);
    update_speed(0);
}

//ADC
void ADC0_init(void) {
    SIM->SCGC6 |= SIM_SCGC6_ADC0_MASK;
    SIM->SCGC5 |= SIM_SCGC5_PORTE_MASK;
    PORTE->PCR[20] = PORT_PCR_MUX(0);
    ADC0->CFG1 = ADC_CFG1_MODE(3) | ADC_CFG1_ADICLK(0); // 16 bits
}

uint16_t ADC0_read(void) {
    ADC0->SC1[0] = 0;
    while(!(ADC0->SC1[0] & ADC_SC1_COCO_MASK));
    return (uint16_t)ADC0->R[0];
}

//Push buttons
void buttons_init(void) {
    SIM->SCGC5 |= SIM_SCGC5_PORTA_MASK;
    PORTA->PCR[12] = PORT_PCR_MUX(1) | PORT_PCR_IRQC(0xA) | PORT_PCR_PE_MASK | PORT_PCR_PS_MASK;
    PORTA->PCR[13] = PORT_PCR_MUX(1) | PORT_PCR_IRQC(0xA) | PORT_PCR_PE_MASK | PORT_PCR_PS_MASK;
    PTA->PDDR &= ~(BTN_MENU | BTN_STOP);
    NVIC_EnableIRQ(PORTA_IRQn);
}

//LCD
void LCD_init(void) {
    SIM->SCGC5 |= (SIM_SCGC5_PORTD_MASK | SIM_SCGC5_PORTA_MASK);
    for(int i = 4; i <= 7; i++) { PORTD->PCR[i] = PORT_PCR_MUX(1); }
    PORTA->PCR[2] = PORT_PCR_MUX(1);
    PORTA->PCR[5] = PORT_PCR_MUX(1);
    PTA->PDDR |= (RS | EN);
    PTD->PDDR |= 0xF0;
    delayMs(60);
    LCD_command(0x33); LCD_command(0x32); LCD_command(0x28);
    LCD_command(0x0C); LCD_command(0x01);
    delayMs(5);
}

void LCD_command(unsigned char cmd) {
    PTA->PCOR = RS; LCD_nibble(cmd); LCD_nibble(cmd << 4); delayMs(2);
}

void LCD_data(unsigned char data) {
    PTA->PSOR = RS; LCD_nibble(data); LCD_nibble(data << 4); delayMs(2);
}

void LCD_print(char *str) {
    while(*str) { LCD_data(*str++); }
}

void LCD_nibble(unsigned char data) {
    PTD->PDOR = (PTD->PDOR & 0x0F) | (data & 0xF0);
    PTA->PSOR = EN; delayUs(20); PTA->PCOR = EN;
}

//Keypad
void keypad_init(void) {
    SIM->SCGC5 |= SIM_SCGC5_PORTC_MASK;
    for(int i = 0; i < 8; i++) {
        PORTC->PCR[i] = PORT_PCR_MUX(1) | PORT_PCR_PE_MASK | PORT_PCR_PS_MASK;
    }
    PTC->PDDR = 0x0F;
}

char keypad_getkey(void) {
    int row, col;
    const char keys[4][4] = {{'1','2','3','A'},{'4','5','6','B'},{'7','8','9','C'},{'*','0','#','D'}};
    for(row = 0; row < 4; row++) {
        PTC->PDDR = 0x0F; PTC->PDOR = ~(1 << row) & 0x0F; delayUs(20);
        col = PTC->PDIR & 0xF0;
        if(col != 0xF0) {
            delayMs(20); // Debounce
            if(col == 0xE0) return keys[row][0];
            if(col == 0xD0) return keys[row][1];
            if(col == 0xB0) return keys[row][2];
            if(col == 0x70) return keys[row][3];
        }
    }
    return 0;
}

void show_menu(void) {
    LCD_command(0x01); LCD_print("SET INPUT MODE");
    LCD_command(0xC0); LCD_print("1: M     2: A");
}

void delayUs(int n) { for(int i = 0; i < n * 10; i++); }
void delayMs(int n) { for(int i = 0; i < n * 5000; i++); }
